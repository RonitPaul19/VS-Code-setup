{
  // Vim
  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.leader": "<space>",
  "vim.ignorecase": true,
  "vim.smartcase": true,

  // Vim normal mode keybindings
  "vim.normalModeKeyBindingsNonRecursive": [
    // Save
    { "before": ["leader", "s"], "commands": ["workbench.action.files.save"] },
    // Redo
    { "before": ["U"], "after": ["<C-r>"] },
    // Clear search highlight
    { "before": ["<Esc>"], "commands": [":nohlsearch"] },
    // Soft-wrap line navigation
    { "before": ["j"], "after": ["g", "j"] },
    { "before": ["k"], "after": ["g", "k"] },
    // Word navigation
    { "before": ["w"], "commands": ["cursorWordPartRight"] },
    { "before": ["b"], "commands": ["cursorWordPartLeft"] },
    // Go to definition / type / implementation / references
    { "before": ["leader", "g", "d"], "commands": ["editor.action.revealDefinition"] },
    { "before": ["leader", "g", "y"], "commands": ["editor.action.goToTypeDefinition"] },
    { "before": ["leader", "g", "i"], "commands": ["editor.action.goToImplementation"] },
    { "before": ["leader", "g", "r"], "commands": ["editor.action.goToReferences"] },
    // Symbol & line navigation
    { "before": ["leader", "g", "s"], "commands": ["workbench.action.gotoSymbol"] },
    { "before": ["leader", "g", "l"], "commands": ["workbench.action.gotoLine"] },
    { "before": ["leader", "l", "e", "l"], "commands": ["workbench.action.navigateToLastEditLocation"] },
    // Search & command palette
    { "before": ["leader", "s", "s"], "commands": ["workbench.action.showAllSymbols"] },
    { "before": ["leader", "c", "p"], "commands": ["workbench.action.showCommands"] },
    { "before": ["leader", "p", "f"], "commands": ["workbench.action.quickOpen"] },
    // Peek
    { "before": ["leader", "v", "d"], "commands": ["editor.action.peekDefinition"] },
    { "before": ["leader", "v", "i"], "commands": ["editor.action.peekImplementation"] },
    { "before": ["leader", "v", "t"], "commands": ["editor.action.peekTypeDefinition"] },
    // Find & replace
    { "before": ["leader", "f", "f"], "commands": ["actions.find"] },
    { "before": ["leader", "p", "g"], "commands": ["workbench.action.findInFiles"] },
    { "before": ["leader", "r", "g"], "commands": ["workbench.action.replaceInFiles"] },
    // Refactoring & code actions
    { "before": ["leader", "r", "e"], "commands": ["editor.action.rename"] },
    { "before": ["leader", "r", "f"], "commands": ["editor.action.refactor"] },
    { "before": ["leader", "q", "f"], "commands": ["editor.action.quickFix"] },
    { "before": ["leader", "s", "g"], "commands": ["editor.action.triggerSuggest"] },
    { "before": ["leader", "f", "c"], "commands": ["editor.action.formatDocument"] },
    { "before": ["leader", "o", "i"], "commands": ["editor.action.organizeImports"] },
    // File & editor management
    { "before": ["leader", "r", "l"], "commands": ["workbench.action.openRecent"] },
    { "before": ["leader", "c", "f"], "commands": ["workbench.action.closeActiveEditor"] },
    { "before": ["leader", "c", "a"], "commands": ["workbench.action.closeAllEditors"] },
    { "before": ["leader", "o", "f"], "commands": ["workbench.action.files.openFile"] },
    { "before": ["leader", "r", "w"], "commands": ["workbench.action.reloadWindow"] },
    { "before": ["leader", "o", "s"], "commands": ["workbench.action.openSettingsJson"] },
    // Sidebar & splits
    { "before": ["leader", "e"], "commands": ["workbench.view.explorer"] },
    { "before": ["leader", "w", "v"], "commands": ["workbench.action.splitEditor"] },
    { "before": ["leader", "w", "h"], "commands": ["workbench.action.splitEditorDown"] },
    { "before": ["leader", "w", "w"], "commands": ["workbench.action.joinTwoGroups"] },
    { "before": ["leader", "w", "a"], "commands": ["workbench.action.evenEditorWidths"] },
    // Code runner
    { "before": ["leader", "r"], "commands": ["code-runner.run"] },
    //terminal
    { "before": ["leader", "t", "t"], "commands": ["workbench.terminal.toggleTerminal"] }
  ],

  // Vim visual mode keybindings
  "vim.visualModeKeyBindingsNonRecursive": [
    // Paste without yanking
    { "before": ["p"], "after": ["P"] },
    // Word navigation
    { "before": ["w"], "commands": ["cursorWordPartRightSelect"] },
    { "before": ["b"], "commands": ["cursorWordPartLeftSelect"] }
  ],

  // Performance
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  },

  // Workbench & theme
  "workbench.iconTheme": "material-icon-theme",
  "material-icon-theme.hidesExplorerArrows": true,
  "workbench.tree.indent": 10,
  "workbench.productIconTheme": "material-product-icons",
  "workbench.colorTheme": "Rosé Pine",
  "workbench.statusBar.visible": false,
  "workbench.activityBar.location": "hidden",
  "workbench.sideBar.location": "right",
  "workbench.tree.renderIndentGuides": "none",
  "workbench.list.smoothScrolling": true,
  "workbench.tree.enableStickyScroll": false,

  // Editor UI
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.minimap.enabled": false,
  "breadcrumbs.enabled": false,
  "editor.renderLineHighlight": "none",
  "editor.matchBrackets": "never",
  "editor.guides.indentation": false,
  "editor.occurrencesHighlight": "off",
  "editor.renderWhitespace": "none",
  "editor.showFoldingControls": "never",
  "editor.stickyScroll.enabled": false,

  // Color customizations
  "workbench.colorCustomizations": {
    "editorCursor.background": "#000000",
    "editorOverviewRuler.wordHighlightStrongForeground": "#0000",
    "editorOverviewRuler.selectionHighlightForeground": "#0000",
    "editorOverviewRuler.rangeHighlightForeground": "#0000",
    "editorOverviewRuler.wordHighlightForeground": "#0000",
    "editorOverviewRuler.bracketMatchForeground": "#0000",
    "editorOverviewRuler.findMatchForeground": "#0000",
    "editorOverviewRuler.modifiedForeground": "#0000",
    "editorOverviewRuler.deletedForeground": "#0000",
    "editorOverviewRuler.warningForeground": "#0000",
    "editorOverviewRuler.addedForeground": "#0000",
    "editorOverviewRuler.errorForeground": "#0000",
    "editorOverviewRuler.infoForeground": "#0000",
    "editorOverviewRuler.border": "#0000",
    "[Rosé Pine]": {
      "tab.activeBackground": "#00000000",
      "tab.inactiveBackground": "#6e6a861a"
    }
  },

  // Window chrome
  "window.titleBarStyle": "native",
  "window.customTitleBarVisibility": "never",
  "window.customMenuBarAltFocus": false,
  "window.menuBarVisibility": "hidden",
  "window.enableMenuBarMnemonics": false,

  // Typography
  "editor.fontFamily": "DankMono Nerd Font",
  "editor.fontLigatures": true,
  "editor.fontSize": 19,

  // Cursor
  "editor.cursorStyle": "block",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorBlinking": "solid",

  // Scrolling & animation
  "editor.smoothScrolling": true,
  "terminal.integrated.smoothScrolling": true,

  // Editor padding
  "editor.padding.top": 15,
  "editor.padding.bottom": 15,

  // Indentation
  "editor.tabSize": 2,
  "editor.detectIndentation": false,

  // Files
  "files.autoSave": "afterDelay",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,

  // Code runner
  "code-runner.runInTerminal": true,
  "code-runner.executorMap": {
    "javascript": "cls; node",
    "c": "cls; cd $dir && gcc $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "cpp": "cls; cd $dir && g++ $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "python": "cls; python -u",
    "typescript": "cls; ts-node"
  },
}
